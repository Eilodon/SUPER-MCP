{
  "name": "super-mcp-boilerplate",
  "version": "1.0.0",
  "description": "Ultimate Universal MCP Boilerplate (Local & Cloud) extracted from VECTOR and Fortuna",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate:encryption": "tsx src/scripts/migrate_encryption.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.4.0",
    "jose": "^5.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@9.15.9"
}
